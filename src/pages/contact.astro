---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout title="Inquiries" maxWidth="max-w-5xl">
  <div class="max-w-5xl mx-auto">

    <div class="mb-16">
      <p class="font-body text-lg text-text-muted font-light leading-relaxed mb-6">
        For custom orders, collaborations, or gallery representations, please reach out via the provided form or email directly.
      </p>
      <a href="mailto:admin@foursilverstrings.com.au" class="inline-block text-2xl font-heading italic text-accent hover:text-text transition-colors lowercase">
        admin@foursilverstrings.com.au
      </a>
    </div>

    <div class="bg-white p-8 md:p-12 border border-border">
      <form
        class="space-y-8"
        name="contact"
        method="POST"
        data-netlify="true"
        data-netlify-recaptcha="true"
      >
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-3">
            <label class="block text-overline text-text-muted">Name</label>
            <input
              class="w-full p-4 bg-bg-base text-sm focus:bg-white"
              type="text"
              name="name"
              placeholder="Your name"
              required
            />
          </div>
          <div class="space-y-3">
            <label class="block text-overline text-text-muted">Email</label>
            <input
              class="w-full p-4 bg-bg-base text-sm focus:bg-white"
              type="email"
              name="email"
              placeholder="Your email address"
              required
            />
          </div>
        </div>

        <div class="space-y-3">
          <label class="block text-overline text-text-muted">Message</label>
          <textarea
            rows="6"
            class="w-full p-4 bg-bg-base text-sm focus:bg-white resize-none"
            name="message"
            placeholder="Details of your inquiry..."
            required></textarea>
        </div>

        <div data-netlify-recaptcha="true"></div>

        <div class="pt-6">
          <button
            class="btn-primary w-full"
            type="submit"
          >
            Send Message
          </button>
        </div>
      </form>
    </div>

  </div>
</DefaultLayout>
