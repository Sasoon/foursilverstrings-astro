---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout title="Thank You">
  <div class="container-standard pb-32 pt-16 md:pt-24 text-center">
    <div class="max-w-xl mx-auto space-y-8">
      <h1 class="text-5xl md:text-6xl font-heading">Thank You</h1>
      <div class="w-16 h-px bg-border mx-auto"></div>
      <p class="font-body text-text-muted text-lg leading-relaxed font-light">
        Your acquisition has been confirmed. A receipt has been sent to your email.
      </p>
      <div class="pt-8">
        <a href="/paintings" class="btn-underline">Return to Exhibition</a>
      </div>
    </div>
  </div>
</DefaultLayout>
