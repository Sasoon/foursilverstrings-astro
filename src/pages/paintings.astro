---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import { getCollection } from "astro:content";

const allPaintings = Object.values(import.meta.glob("./paintings/*.md", { eager: true }));
const sortedPaintings = allPaintings.sort(
  (a: any, b: any) => a.frontmatter.order - b.frontmatter.order,
);
---

<DefaultLayout title="Exhibition">
  <div class="mb-16 md:mb-24">
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading text-text mb-6">Exhibition</h1>
    <div class="w-16 h-px bg-border"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 md:gap-x-12 gap-y-16 md:gap-y-24">
    {
      sortedPaintings.map((painting) => (
        <a
          href={painting.url}
          class="group block no-underline"
        >
          <div class="bg-white p-3 md:p-4 border border-border mb-6 md:mb-8 transition-colors duration-700 group-hover:border-text/30">
            <div class="relative overflow-hidden bg-bg-alt aspect-[4/5]">
              <img
                src={
                  painting.frontmatter.image1 +
                  "-/resize/800x/-/quality/smart/-/format/webp/"
                }
                alt={painting.frontmatter.title}
                class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-[1.03]"
                transition:name={`painting-${painting.frontmatter.identifier}`}
              />
            </div>
          </div>
          
          <div class="text-center px-4">
            <h2 class="text-2xl md:text-3xl font-heading text-text group-hover:text-text-muted transition-colors duration-500">
              {painting.frontmatter.title}
            </h2>
          </div>
        </a>
      ))
    }
  </div>
</DefaultLayout>
