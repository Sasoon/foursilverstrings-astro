---
import HomeLayout from "../layouts/HomeLayout.astro";
---

<HomeLayout>
  <div
    class="container-standard min-h-[90vh] flex flex-col lg:flex-row items-start justify-between pt-24 md:pt-32 pb-16 md:pb-24 gap-12 md:gap-24"
  >
    <div
      class="w-full lg:w-5/12 space-y-8 md:space-y-12 z-10 pt-4 md:pt-0 lg:-mt-4 text-center lg:text-left"
    >
      <h1
        class="text-5xl md:text-6xl lg:text-[5.5rem] font-heading leading-[1.05] tracking-tight text-text"
      >
        The delicate intersection of <span class="italic text-accent"
          >sound</span
        >, colour &amp; movement.
      </h1>

      <div class="w-12 h-px bg-border mx-auto lg:mx-0"></div>

      <p
        class="font-body text-sm md:text-base text-text-muted leading-loose max-w-md mx-auto lg:mx-0"
      >
        Based in Sydney. Exploring the ethereal space between classical
        discipline and vibrant abstract expressionism.
      </p>

      <div class="pt-4 flex justify-center lg:justify-start">
        <a href="/paintings" class="btn-underline"> Enter Exhibition </a>
      </div>
    </div>

    <!-- Gallery Presentation -->
    <div class="w-full lg:w-7/12 relative mt-8 lg:mt-0">
      <div class="p-3 md:p-6 bg-white border border-border">
        <div class="relative overflow-hidden bg-bg-alt">
          <img
            class="w-full h-auto max-h-[75vh] object-cover transition-transform duration-[2s] hover:scale-[1.02]"
            src="https://ucarecdn.com/b3260e5f-9683-42bf-b323-b390fb8c7899/-/quality/smart/-/format/auto/"
            alt="Four Silver Strings artwork"
            transition:name="hero-image"
          />
        </div>
      </div>
    </div>
  </div>
</HomeLayout>
