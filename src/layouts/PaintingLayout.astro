---
import DefaultLayout from "./DefaultLayout.astro";
const { frontmatter } = Astro.props;

const images = [
  frontmatter.image1,
  frontmatter.image2,
  frontmatter.image3,
  frontmatter.image4,
  frontmatter.image5,
  frontmatter.image6,
  frontmatter.image7,
  frontmatter.image8,
].filter(Boolean);

const sizes = [
  { key: "sm", label: frontmatter.price1_label, price: frontmatter.price1 },
  { key: "md", label: frontmatter.price2_label, price: frontmatter.price2 },
  { key: "lg", label: frontmatter.price3_label, price: frontmatter.price3 },
];

const frames = [
  { label: frontmatter.thin_frame1_label, surcharge: { sm: 20, md: 30, lg: 40 } },
  { label: frontmatter.thin_frame2_label, surcharge: { sm: 20, md: 30, lg: 40 } },
  { label: frontmatter.thick_frame1_label, surcharge: { sm: 30, md: 40, lg: 50 } },
  { label: frontmatter.thick_frame2_label, surcharge: { sm: 30, md: 40, lg: 50 } },
];

const initialPrice = sizes[1].price + frames[0].surcharge.md;
---

<DefaultLayout title={frontmatter.title}>
  <style>
    main > div.container-standard { padding-left: 0; padding-right: 0; max-width: none; }
  </style>

  <div class="px-6 md:px-12 lg:px-24 pb-32 pt-24 md:pt-32">
    
    <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 items-start">
      
      <!-- Gallery Column -->
      <div class="w-full lg:w-[60%] lg:sticky lg:top-32">
        <div class="bg-white p-4 md:p-6 border border-border mb-8">
          <div class="painting-gallery flex overflow-x-auto snap-x snap-mandatory gap-6 scroll-smooth" id="gallery">
            {
              images.map((img: string, i: number) => (
                <div class="w-full shrink-0 snap-center flex items-center justify-center relative bg-bg-alt">
                  <img
                    src={img + "-/resize/1600x/-/quality/smart/-/format/webp/"}
                    alt={`${frontmatter.title} plate ${i + 1}`}
                    class="w-full h-auto max-h-[80vh] object-cover"
                    {...(i === 0 ? { "transition:name": `painting-${frontmatter.identifier}` } : { "transition:animate": "fade" })}
                  />
                </div>
              ))
            }
          </div>
        </div>
        
        <!-- Thumbnails Dock -->
        {images.length > 1 && (
          <div class="flex gap-4 overflow-x-auto pb-4" id="thumbnails">
            {images.map((img: string, i: number) => (
              <button
                type="button"
                class={`shrink-0 w-20 h-20 overflow-hidden border border-border cursor-pointer transition-all duration-300 thumbnail-btn ${i === 0 ? 'opacity-100 ring-1 ring-text ring-offset-2 ring-offset-bg-base' : 'opacity-50 hover:opacity-100'}`}
                data-index={i}
              >
                <img
                  src={img + "-/resize/200x200/-/quality/smart/-/format/webp/"}
                  alt={`Thumbnail ${i + 1}`}
                  class="w-full h-full object-cover"
                />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Details Column -->
      <div class="w-full lg:w-[40%]">
        
        <div class="mb-16">
          <nav class="flex items-center text-overline text-text-muted mb-6 space-x-3">
            <a href="/paintings" class="hover:text-accent transition-colors">Exhibition</a>
            <span class="w-4 h-px bg-border"></span>
            <span class="text-accent">{frontmatter.title}</span>
          </nav>
          <h1 class="text-5xl md:text-6xl font-heading mb-8 leading-tight">{frontmatter.title}</h1>
          <div class="w-16 h-px bg-border mb-8"></div>
          <p class="font-body text-sm md:text-base text-text-muted leading-loose font-light">
            {frontmatter.description}
          </p>
        </div>

        <div class="bg-white border border-border p-8 md:p-12 space-y-12">
          
          <!-- Size -->
          <div class="space-y-4">
            <label class="block text-overline text-text-muted">Dimension</label>
            <div class="flex border border-border" id="size-selector">
              {sizes.map((size, i) => (
                <button
                  type="button"
                  class={`flex-1 py-4 text-[10px] font-semibold uppercase tracking-[0.2em] border-r border-border last:border-r-0 transition-all duration-300 ${i === 1 ? 'bg-text text-bg-base' : 'bg-transparent text-text hover:bg-bg-alt'}`}
                  data-size={size.key}
                  data-price={size.price}
                >
                  {size.label}
                </button>
              ))}
            </div>
          </div>

          <!-- Frame -->
          <div class="space-y-4 relative">
            <label class="block text-overline text-text-muted">Mounting</label>
            <div class="relative">
              <select
                id="frame-selector"
                class="w-full p-5 bg-transparent border border-border text-xs font-semibold uppercase tracking-widest text-text appearance-none focus:outline-none focus:border-text cursor-pointer"
              >
                {frames.map((frame) => (
                  <option value={frame.label} data-surcharge-sm={frame.surcharge.sm} data-surcharge-md={frame.surcharge.md} data-surcharge-lg={frame.surcharge.lg}>
                    {frame.label}
                  </option>
                ))}
              </select>
              <div class="absolute inset-y-0 right-5 flex items-center pointer-events-none text-text-muted">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>

          <!-- Quantity -->
          <div class="space-y-4">
            <label class="block text-overline text-text-muted">Units</label>
            <input
              type="number"
              id="qty"
              class="w-full p-5 bg-transparent border border-border text-lg font-semibold text-center focus:outline-none focus:border-text"
              min="1"
              value="1"
            />
          </div>

          <!-- Total & Action -->
          <div class="pt-8 border-t border-border mt-12">
            <div class="flex justify-between items-baseline mb-10">
              <span class="text-overline text-text-muted">Total</span>
              <span class="text-4xl font-heading" id="price-display">${initialPrice}</span>
            </div>
            
            <button type="button" class="btn-primary w-full" id="add-to-cart" disabled>
              Acquire Piece
            </button>
            <p class="text-center text-xs text-accent mt-6 font-medium tracking-wide">Acquisition unavailable at this time.</p>
          </div>
          
        </div>
      </div>
    </div>
  </div>

  <style>
    .painting-gallery::-webkit-scrollbar {
      display: none;
    }
    .painting-gallery {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script>
    function initPaintingPage() {
      const sizeButtons = document.querySelectorAll<HTMLButtonElement>("#size-selector button");
      const frameSelector = document.querySelector<HTMLSelectElement>("#frame-selector");
      const qtyInput = document.querySelector<HTMLInputElement>("#qty");
      const priceDisplay = document.querySelector<HTMLSpanElement>("#price-display");
      const gallery = document.querySelector<HTMLElement>("#gallery");
      const thumbnails = document.querySelectorAll<HTMLButtonElement>(".thumbnail-btn");

      if (!sizeButtons.length || !frameSelector || !qtyInput || !priceDisplay) return;

      function getSelectedSize(): string {
        const btn = document.querySelector<HTMLButtonElement>("#size-selector button.bg-text");
        return btn?.dataset.size || "md";
      }

      function getBasePrice(): number {
        const btn = document.querySelector<HTMLButtonElement>("#size-selector button.bg-text");
        return parseInt(btn?.dataset.price || "0");
      }

      function getFrameSurcharge(): number {
        const opt = frameSelector!.selectedOptions[0];
        const size = getSelectedSize();
        const key = "surcharge" + size.charAt(0).toUpperCase() + size.slice(1);
        return parseInt(opt?.dataset[key] || "0");
      }

      function updatePrice() {
        const qtyInputVal = parseInt(qtyInput!.value);
        const qty = isNaN(qtyInputVal) || qtyInputVal < 1 ? 1 : qtyInputVal;
        const total = (getBasePrice() + getFrameSurcharge()) * qty;
        priceDisplay!.textContent = "$" + total;
      }

      sizeButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          sizeButtons.forEach((b) => {
            b.classList.remove("bg-text", "text-bg-base");
            b.classList.add("bg-transparent", "text-text");
          });
          btn.classList.remove("bg-transparent", "text-text");
          btn.classList.add("bg-text", "text-bg-base");
          qtyInput!.value = "1";
          updatePrice();
        });
      });

      frameSelector.addEventListener("change", updatePrice);
      qtyInput.addEventListener("change", updatePrice);

      if (gallery && thumbnails.length) {
        thumbnails.forEach((btn) => {
          btn.addEventListener("click", () => {
            const index = parseInt(btn.dataset.index || "0");
            const imgs = gallery.querySelectorAll(".snap-center");
            if (imgs[index]) {
              imgs[index].scrollIntoView({
                behavior: "smooth",
                block: "nearest",
                inline: "center",
              });
            }
            thumbnails.forEach((t) => {
              t.classList.remove("opacity-100", "ring-1", "ring-text", "ring-offset-2", "ring-offset-bg-base");
              t.classList.add("opacity-50");
            });
            btn.classList.remove("opacity-50");
            btn.classList.add("opacity-100", "ring-1", "ring-text", "ring-offset-2", "ring-offset-bg-base");
          });
        });
      }

      updatePrice();
    }

    document.addEventListener("astro:page-load", initPaintingPage);
  </script>
</DefaultLayout>
