---
const { title } = Astro.props;
---

<header class="section-padding text-center relative">
  {title && (
    <div class="space-y-6">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading text-text">
        {title}
      </h1>
      <div class="w-24 h-px bg-accent/60 mx-auto"></div>
    </div>
  )}
</header>
