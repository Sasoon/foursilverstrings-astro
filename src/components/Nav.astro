---
import Instagram from "./Instagram.astro";

const currentPath = Astro.url.pathname;
---

<header
  class="container-standard py-5 flex flex-wrap md:flex-nowrap items-center justify-between"
  role="banner"
>
  <div class="w-full md:w-auto flex items-center justify-between">
    <a
      class="text-xl md:text-2xl font-heading tracking-tight text-text hover:opacity-70 transition-opacity"
      rel="author"
      href="/"
    >
      Four Silver Strings
    </a>

    <!-- Mobile Toggle -->
    <button
      type="button"
      id="menu-toggle"
      class="md:hidden text-overline text-text p-2"
      aria-label="Menu"
    >
      Menu
    </button>
  </div>

  <nav
    id="menu"
    class="hidden md:flex absolute md:static top-full left-0 w-full md:w-auto bg-bg-base md:bg-transparent border-b border-border md:border-none p-6 md:p-0 z-40"
  >
    <ul
      class="flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10 text-sm font-body tracking-wide text-text-muted"
    >
      <li>
        <a
          class={`link-underline ${currentPath.startsWith("/paintings") ? "active text-accent font-medium" : ""}`}
          href="/paintings">Pieces</a>
      </li>
      <li>
        <a
          class={`link-underline ${currentPath.startsWith("/about") ? "active text-accent font-medium" : ""}`}
          href="/about">Artist</a>
      </li>
      <li>
        <a
          class={`link-underline ${currentPath.startsWith("/faq") ? "active text-accent font-medium" : ""}`}
          href="/faq">FAQ</a>
      </li>
      <li>
        <a
          class={`link-underline ${currentPath.startsWith("/contact") ? "active text-accent font-medium" : ""}`}
          href="/contact">Contact</a>
      </li>
      <li class="hidden md:block w-px h-4 bg-border"></li>
      <li>
        <a href="#" class="hover:text-accent transition-colors"
          ><Instagram /></a>
      </li>
    </ul>
  </nav>
</header>

<script>
  function initNav() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("menu");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        menu.classList.toggle("hidden");
        toggle.textContent = menu.classList.contains("hidden")
          ? "Menu"
          : "Close";
      });
    }
  }
  document.addEventListener("astro:page-load", initNav);
</script>
